#!/bin/bash
echo "=== Package Sync Started"
{{ if eq .chezmoi.os "darwin" -}}

# Environment state hashes — changes here trigger run_onchange re-execution
# brew leaves: {{ output "brew" "leaves" | sha256sum }}
# brew casks: {{ output "brew" "list" "--cask" "-1" | sha256sum }}
# brew taps: {{ output "brew" "tap" | sha256sum }}

# Generate combined Brewfile in a temp file
brewfile=$(mktemp)
cat > "$brewfile" <<BREWEOF
{{ range .packages.universal.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.universal.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.universal.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.universal.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}

{{ if .isWorkComputer -}}
{{ range .packages.work.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.work.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.work.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.work.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}

{{ else -}}

{{ range .packages.private.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.private.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.private.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.private.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
{{ end -}}
BREWEOF

# Tap and trust all taps
{{ range .packages.universal.taps -}}
brew tap --force {{ . | quote | replace " " "\" \"" }}
brew trust {{ . | quote | replace " " "\" \"" }}
{{ end -}}
{{ if .isWorkComputer -}}
{{ range .packages.work.taps -}}
brew tap --force {{ . | quote | replace " " "\" \"" }}
brew trust {{ . | quote | replace " " "\" \"" }}
{{ end -}}
{{ else -}}
{{ range .packages.private.taps -}}
brew tap --force {{ . | quote | replace " " "\" \"" }}
brew trust {{ . | quote | replace " " "\" \"" }}
{{ end -}}
{{ end -}}

# Install packages
brew bundle --file="$brewfile"

# Warn about and remove undeclared packages
undeclared=$(brew bundle cleanup --file="$brewfile" 2>/dev/null)
if [[ -n "$undeclared" ]]; then
    echo ""
    echo "WARNING: Removing packages not declared in packages.yaml:"
    echo "$undeclared"
    brew bundle cleanup --force --file="$brewfile"
    brew autoremove
fi
rm -f "$brewfile"

{{ else if eq .chezmoi.os "linux" -}}
# Ubuntu/Debian only for now, but could be extended to other distros in the future
{{ if lookPath "apt-get" -}}

# Environment state hashes — changes here trigger run_onchange re-execution
# apt state: {{ output "sh" "-c" "dpkg-query -W -f='${Package}\\n' 2>/dev/null; cat /etc/apt/sources.list.d/*.list 2>/dev/null; true" | sha256sum }}

# Sections to install: universal always, plus work or private (mirrors the macOS logic)
{{ $sections := list .linux_packages.universal -}}
{{ if .isWorkComputer -}}
{{ $sections = append $sections .linux_packages.work -}}
{{ else -}}
{{ $sections = append $sections .linux_packages.private -}}
{{ end -}}

sudo install -m 0755 -d /etc/apt/keyrings

# Repository signing keys
{{ range $sections -}}
{{ range .keyrings -}}
if [[ ! -f /etc/apt/keyrings/{{ .name }}.gpg ]]; then
{{ if .dearmor -}}
    curl -fsSL {{ .url | quote }} | sudo gpg --dearmor -o /etc/apt/keyrings/{{ .name }}.gpg
{{ else -}}
    curl -fsSL {{ .url | quote }} | sudo tee /etc/apt/keyrings/{{ .name }}.gpg > /dev/null
{{ end -}}
    sudo chmod a+r /etc/apt/keyrings/{{ .name }}.gpg
fi
{{ end -}}
{{ end -}}

# apt sources
{{ range $sections -}}
{{ range .sources -}}
echo {{ .line | quote }} | sudo tee /etc/apt/sources.list.d/{{ .name }}.list > /dev/null
{{ end -}}
{{ end -}}

sudo apt-get update

# Install apps
apps=()
{{ range $sections -}}
{{ range .apps -}}
apps+=({{ . | quote }})
{{ end -}}
{{ end -}}
if [[ ${#apps[@]} -gt 0 ]]; then
    sudo apt-get install -y "${apps[@]}"
fi

{{ end -}}
{{ end -}}
echo "=== Package Sync Complete"